# Скопируйте в .env.docker и подставьте значения.
# Используется при: docker compose build / docker compose up
#
# Для мобильного APK используйте .env.local (см. build-apk.sh) — там
# NEXT_PUBLIC_OLLAMA_USE_SAME_ORIGIN_PROXY должен быть false или отсутствовать.

# ChatService API (браузер ходит с клиента на этот URL)
NEXT_PUBLIC_CHAT_API_URL=https://chat.pirogov.ai

# Ollama: upstream для nginx-прокси в контейнере (runtime, можно менять без пересборки)
OLLAMA_UPSTREAM=https://llm.oclinica.ru

# Вшиваются в JS при docker build (как при npm run build для APK)
NEXT_PUBLIC_OLLAMA_BASE_URL=https://llm.oclinica.ru
NEXT_PUBLIC_OLLAMA_MODEL=gemma3:4b
NEXT_PUBLIC_OLLAMA_API_KEY=
NEXT_PUBLIC_OLLAMA_API_KEY_HEADER=

# Обязательно true для веба в Docker (прокси /api/ollama-proxy в nginx)
NEXT_PUBLIC_OLLAMA_USE_SAME_ORIGIN_PROXY=true

# Опционально
# NEXT_PUBLIC_MEET_SERVICE_URL=
# NEXT_PUBLIC_TRANSCRIBE_URL=
# NEXT_PUBLIC_OAUTH_NATIVE_BRIDGE_URL=

# Порт публикации веб-UI на хосте
CHATAPP_HTTP_PORT=3080
