# Локальная разработка и сборка APK (build-apk.sh / npm run build + cap sync).
# Для Docker-веба: .env.docker.example → .env.docker

NEXT_PUBLIC_CHAT_API_URL=https://chat.pirogov.ai

# Ollama (AI-помощник)
NEXT_PUBLIC_OLLAMA_BASE_URL=https://llm.oclinica.ru
NEXT_PUBLIC_OLLAMA_MODEL=gemma3:4b
# Секрет: Authorization: Bearer <ключ>. Не коммитьте в git.
#NEXT_PUBLIC_OLLAMA_API_KEY=
# NEXT_PUBLIC_OLLAMA_API_KEY_HEADER=X-API-Key

# Только для Docker-веба (nginx проксирует /api/ollama-proxy). Для APK не включайте.
# NEXT_PUBLIC_OLLAMA_USE_SAME_ORIGIN_PROXY=true

# Опционально
# NEXT_PUBLIC_MEET_SERVICE_URL=
# NEXT_PUBLIC_TRANSCRIBE_URL=
# NEXT_PUBLIC_OAUTH_NATIVE_BRIDGE_URL=
